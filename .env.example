# ─────────────────────────────────────────────────────────────────────
# Cookbook — environment variables (template)
#
# Copy to `.env` and adjust:  cp .env.example .env
# Never commit a real `.env` — only this template is tracked.
#
# Local dev (`docker compose --profile dev up`) works out of the box with
# the defaults baked into docker-compose.yml, so a `.env` is optional there.
# A `.env` IS required for the production deploy (deploy/blue-green) and is
# recommended for the monitoring stack.
# ─────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ────────────────────────────────────────────
# Read by both the backend and the postgres container. Safe defaults are
# used in local dev; set real values for production.
POSTGRES_HOST=postgres        # Postgres hostname (prod: the database VM's private IP)
POSTGRES_PORT=5432
POSTGRES_DB=cookbook
POSTGRES_USER=cookbook
POSTGRES_PASSWORD=change-me    # use a strong password in production

# Alternative to the five POSTGRES_* vars above: one connection string.
# If set, it takes precedence over them.
# DATABASE_URL=postgres://cookbook:change-me@localhost:5432/cookbook

# ── Backend auth ─────────────────────────────────────────────────────
# Secret used to sign JWTs. The backend falls back to an insecure built-in
# default if this is unset — ALWAYS set a long random value in production.
#   generate with:  openssl rand -hex 32
JWT_SECRET=change-me

# Port the backend listens on inside its container (default 3000).
# PORT=3000

# ── Production deploy (deploy/blue-green) ────────────────────────────
# GitHub org/user that owns the GHCR images: ghcr.io/<owner>/cookbook-*
GITHUB_OWNER=balladebaderne
# Image tags to deploy (default: latest).
# BACKEND_IMAGE_TAG=latest
# FRONTEND_IMAGE_TAG=latest
# Which backend color nginx proxies to. Managed by the deploy script via
# active-color.env (127.0.0.1:3001 = blue, 127.0.0.1:3002 = green).
# BACKEND_HOST=127.0.0.1:3001

# ── Monitoring (Grafana) ─────────────────────────────────────────────
# Grafana admin login. Defaults to admin/admin — CHANGE in production
# (self-sign-up is disabled).
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
